@model Order

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

<div>
    <h4>Order</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            <label asp-for="Date"></label>
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Date)
        </dd>
        <dt class = "col-sm-2">
            <label asp-for="TotalPrice"></label>
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.TotalPrice)
        </dd>
        <dt class = "col-sm-2">
            <label asp-for="Customer"></label>
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Customer.Name)
        </dd>
    </dl>
</div>
<div>
    <a class="btn btn-warning m-2" asp-action="Edit" asp-route-id="@Model?.ID">Edit</a>
	<a class="btn btn-danger m-2" asp-action="Delete" asp-route-id="@Model?.ID">Delete</a>
</div>
<a class="btn btn-secondary m-2" asp-action="Index">Back to List</a>
