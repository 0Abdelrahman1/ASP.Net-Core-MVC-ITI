@model Department

@{
    ViewData["Title"] = "Delete Department";
}

<h1>Delete Department</h1>

<div class="alert alert-danger" role="alert">
    <strong>Warning!</strong> Are you sure you want to delete this department?
</div>

<div class="card">
    <div class="card-body">
        <p><strong>Department ID:</strong> @Model.DeptID</p>
        <p><strong>Name:</strong> @Model.Name</p>
        <p><strong>Description:</strong> @Model.Description</p>
        
        @if (Model.Employees != null && Model.Employees.Count > 0)
        {
            <div class="alert alert-warning mt-3">
                <strong>Note:</strong> This department has @Model.Employees.Count employee(s) assigned to it.
                <ul>
                    @foreach (var emp in Model.Employees)
                    {
                        <li>@emp.Name</li>
                    }
                </ul>
            </div>
        }
    </div>
</div>

<form asp-area="HR" asp-controller="Department" asp-action="Delete" method="post" class="mt-3">
    <input type="hidden" asp-for="DeptID" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-area="HR" asp-controller="Department" asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
