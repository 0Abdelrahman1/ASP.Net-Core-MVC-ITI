@model Department

@{
    ViewData["Title"] = "Create Department";
}

<h1>Create New Department</h1>

<form asp-area="HR" asp-controller="Department" asp-action="Create" method="post">
    <div class="form-group mb-3">
        <label asp-for="Name" class="form-label">Department Name</label>
        <input asp-for="Name" class="form-control" required />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="Description" class="form-label">Description</label>
        <textarea asp-for="Description" class="form-control" rows="4"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <div class="form-group">
        <button type="submit" class="btn btn-primary">Create</button>
        <a asp-area="HR" asp-controller="Department" asp-action="Index" class="btn btn-secondary">Cancel</a>
    </div>
</form>
