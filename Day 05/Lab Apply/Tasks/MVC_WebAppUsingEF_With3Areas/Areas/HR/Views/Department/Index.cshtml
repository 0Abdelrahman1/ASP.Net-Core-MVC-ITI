@model IEnumerable<Department>

@{
    ViewData["Title"] = "Departments";
}

<h1>Departments</h1>

<table class="table table-bordered table-success">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.DeptID)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Name)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Description)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Employees)
            </th>
            <th>Details</th>
            <th>Edit</th>
            <th>Delete</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.DeptID)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Name)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Description)
                </td>
                <td>
                    @item.Employees?.Count ?? 0
                </td>
                <td>
                    <a asp-area="HR" asp-controller="Department" asp-action="Details" asp-route-id="@item.DeptID" class="btn btn-info">Details</a>
                </td>
                <td>
                    <a asp-area="HR" asp-controller="Department" asp-action="Edit" asp-route-id="@item.DeptID" class="btn btn-warning">Edit</a>
                </td>
                <td>
                    <a asp-area="HR" asp-controller="Department" asp-action="Delete" asp-route-id="@item.DeptID" class="btn btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
<p class="text-end">
    <a asp-area="HR" asp-controller="Department" asp-action="Create" class="btn btn-primary">Create New</a>
</p>
