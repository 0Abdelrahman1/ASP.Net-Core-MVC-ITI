

<div class="card" style="width: 18rem;">
    <img src="@ViewData["Picture"]" class="card-img-top" alt="...">
    <div class="card-body">
        <h5 class="card-title">@ViewData["Name"]</h5>
        <p class="card-text"><b>Description:</b> @ViewData["Description"]</p>
        <p class="card-text"><b>Price:</b> @ViewData["Price"]</p>
        <a href="#" class="btn btn-primary">Buy</a>
    </div>
</div>